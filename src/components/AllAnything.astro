---
import AsideCard from "./AsideCard.astro";

interface Props {
  title: string;
  items: string[];
}

const { title, items } = Astro.props;
---

<div class="space-y-8">
  <AsideCard>
    <div class="flex flex-col space-y-1.5 p-6">
      <h1 class="text-2xl font-medium tracking-tight">{title}</h1>
      <p class="text-muted-foreground text-sm">Total {items.length} {title}.</p>
    </div>
  </AsideCard>
  <div class="space-y-8">
    <div class="space-y-4 mx-1">
      <h2 class="text-xl font-medium ml-2">All</h2>
      {items.map((item) => (
        <div class="flex flex-col gap-2">
          <div class="print:rounded-none rounded-xl print:border-none border print:bg-transparent bg-card text-card-foreground print:shadow-none shadow flex flex-row items-center justify-between">
            <div class="space-y-1 inline-flex flex-col h-full p-6 content-start pr-4 w-[calc(100%-128px)]">
              <a href={`/${title.toLowerCase()}/${item}`}>
                <h3 class="font-semibold tracking-tight text-base truncate">{item}</h3>
              </a>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</div>
