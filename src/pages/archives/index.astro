---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import AllAnything from "@/components/AllAnything.astro";
import { getAllArchive, sortByDate } from "@/lib/utils";

const allPosts = await getCollection("post", ({ data, id }) =>
  !data.draft && id !== "about.mdx" && id !== "hobby_project.mdx"
);
const ALL_ARCHIVE = getAllArchive(allPosts);
const items = sortByDate(ALL_ARCHIVE, true);
---

<BaseLayout title="Archives">
  <AllAnything title="Archives" items={items} />
</BaseLayout>
