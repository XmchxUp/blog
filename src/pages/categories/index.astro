---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import AllAnything from "@/components/AllAnything.astro";
import { getAllCategory, sortByCount, filterPublishedPosts } from "@/lib/utils";

const allPosts = filterPublishedPosts(await getCollection("post"));
const ALL_CATEGORY = getAllCategory(allPosts);
const items = sortByCount(ALL_CATEGORY, true);
---

<BaseLayout title="Categories">
  <AllAnything title="Categories" items={items} counts={ALL_CATEGORY} />
</BaseLayout>
