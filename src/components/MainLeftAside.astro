---
import { getCollection } from "astro:content";
import AsideCard from "./AsideCard.astro";
import { getAllCategory, getAllTag, getAllArchive, sortByCount, sortByDate, filterPublishedPosts } from "@/lib/utils";

const TAG_COUNT = 10;
const ARCHIVE_COUNT = 5;
const CATEGORY_COUNT = 5;

const allPosts = await getCollection("post");
const blogPosts = filterPublishedPosts(allPosts);

const ALL_CATEGORY = getAllCategory(blogPosts);
const ALL_TAG = getAllTag(blogPosts);
const ALL_ARCHIVE = getAllArchive(blogPosts);
---

<aside class="-order-1 hidden md:block">
  <div class="flex flex-col gap-3 w-full sticky top-16">
    <!-- Profile Card -->
    <AsideCard className="p-5">
      <div class="flex flex-col items-center text-center">
        <div class="w-20 h-20 rounded-full border-2 border-border overflow-hidden ring-2 ring-primary/20">
          <img src="/me.png" alt="Picture of the author" class="w-full h-full object-cover" width="80" height="80" loading="eager" />
        </div>
        <div class="flex flex-col items-center mt-3 gap-0.5">
          <span class="text-base font-semibold text-foreground">Xmchx</span>
          <span class="text-xs text-muted-foreground">Technology & Life</span>
        </div>
        <div class="flex flex-row gap-0 justify-center w-full mt-4 divide-x divide-border border-t border-border pt-4">
          <div class="flex flex-col gap-0.5 items-center flex-1">
            <span class="text-base font-semibold text-foreground">{blogPosts.length}</span>
            <span class="text-xs text-muted-foreground">Posts</span>
          </div>
          <div class="flex flex-col gap-0.5 items-center flex-1">
            <span class="text-base font-semibold text-foreground">{Object.keys(ALL_CATEGORY).length}</span>
            <span class="text-xs text-muted-foreground">Categories</span>
          </div>
          <div class="flex flex-col gap-0.5 items-center flex-1">
            <span class="text-base font-semibold text-foreground">{Object.keys(ALL_TAG).length}</span>
            <span class="text-xs text-muted-foreground">Tags</span>
          </div>
        </div>
      </div>
    </AsideCard>

    <!-- Categories Card -->
    <AsideCard>
      <div class="px-4 pt-4 pb-1">
        <a href="/categories/" class="text-xs font-semibold uppercase tracking-wider text-muted-foreground hover:text-foreground transition-colors">Categories</a>
      </div>
      <div class="flex flex-col gap-0.5 px-2 pb-3 pt-1">
        {sortByCount(ALL_CATEGORY, true).slice(0, CATEGORY_COUNT).map((category) => (
          <a
            href={`/categories/${category}`}
            class="aside-nav-link"
          >
            <span class="text-sm flex-grow truncate">{category}</span>
            <span class="text-xs text-muted-foreground tabular-nums">{ALL_CATEGORY[category]}</span>
          </a>
        ))}
      </div>
    </AsideCard>

    <!-- Archives Card -->
    <AsideCard>
      <div class="px-4 pt-4 pb-1">
        <a href="/archives/" class="text-xs font-semibold uppercase tracking-wider text-muted-foreground hover:text-foreground transition-colors">Archives</a>
      </div>
      <div class="flex flex-col gap-0.5 px-2 pb-3 pt-1">
        {sortByDate(ALL_ARCHIVE, true).slice(0, ARCHIVE_COUNT).map((archive) => (
          <a
            href={`/archives/${archive}`}
            class="aside-nav-link"
          >
            <span class="text-sm flex-grow truncate">{archive}</span>
            <span class="text-xs text-muted-foreground tabular-nums">{ALL_ARCHIVE[archive]}</span>
          </a>
        ))}
      </div>
    </AsideCard>

    <!-- Tags Card -->
    <AsideCard>
      <div class="px-4 pt-4 pb-1">
        <a href="/tags/" class="text-xs font-semibold uppercase tracking-wider text-muted-foreground hover:text-foreground transition-colors">Tags</a>
      </div>
      <div class="px-3 pb-4 pt-2 flex flex-row flex-wrap gap-1">
        {sortByCount(ALL_TAG, true).slice(0, TAG_COUNT).map((tag) => (
          <a
            href={`/tags/${tag}`}
            class="inline-flex items-center justify-center whitespace-nowrap transition-colors focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring hover:bg-accent hover:text-accent-foreground h-6 rounded-full px-2.5 text-xs font-normal border border-border"
          >
            {tag}
          </a>
        ))}
      </div>
    </AsideCard>
  </div>
</aside>
