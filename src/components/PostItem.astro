---
import { formatDate } from "@/lib/utils";

interface Props {
  slug: string;
  title: string;
  category: string;
  date: string;
  excerpt: string;
  description?: string;
  cover?: string;
}

const { title, slug, category, description, date, excerpt, cover } = Astro.props;
---

<div
  class="group print:rounded-none rounded-xl print:border-none border print:bg-transparent bg-card text-card-foreground print:shadow-none shadow hover:shadow-md transition-shadow duration-200"
  title={title}
>
  {cover && (
    <a href={`/post/${slug}`}>
      <div style="position: relative; width: 100%; padding-bottom: 42.8571%;">
        <img
          src={cover}
          alt={title}
          class="rounded-t-xl w-full object-cover absolute inset-0 h-full"
          loading="lazy"
          width="800"
          height="343"
        />
      </div>
    </a>
  )}
  <div class="p-5 pb-3">
    <div class="flex flex-row items-center gap-2 mb-2">
      <a
        title={category}
        href={`/categories/${category}`}
        class="inline-flex items-center rounded-full border border-primary/30 bg-accent text-accent-foreground px-2.5 py-0.5 text-xs font-medium hover:bg-primary hover:text-primary-foreground transition-colors"
      >
        {category}
      </a>
      <time class="text-xs text-muted-foreground">{formatDate(date)}</time>
    </div>
    <a href={`/post/${slug}`}>
      <h3 class="text-xl font-semibold tracking-tight leading-snug group-hover:text-primary transition-colors">{title}</h3>
    </a>
  </div>
  <div class="px-5 pb-5 pt-0">
    <p class="text-sm text-muted-foreground text-pretty hyphens-auto leading-relaxed line-clamp-2">
      {description ?? excerpt.substring(0, 100)}
    </p>
  </div>
</div>
