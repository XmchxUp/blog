---
import { siteConfig } from "@/config/site";
import NavbarActions from "./react/NavbarActions";
import MobileNavbar from "./react/MobileNavbar";
---

<header class="w-full h-auto sticky top-0 z-40 border-b border-border bg-background/90 backdrop-blur-sm overflow-x-hidden">
  <div class="w-full h-full py-2 md:container">
    <div class="flex flex-row items-center text-foreground justify-between gap-2 lg:gap-4 xl:gap-6 px-4 py-1">
      <a href="/" class="flex flex-row items-center gap-2 shrink-0">
        <span class="font-semibold text-base tracking-tight">{siteConfig.name}</span>
      </a>
      <!-- Desktop nav -->
      <div class="hidden lg:flex lg:flex-row items-center justify-between flex-grow gap-2">
        <nav class="flex flex-1 items-center justify-center gap-1">
          {siteConfig.navItems.map((item) => (
            <a
              href={item.href}
              class="inline-flex h-8 w-max items-center justify-center rounded-md px-3 py-1.5 text-sm font-medium transition-colors text-muted-foreground hover:bg-accent hover:text-accent-foreground"
            >
              {item.label}
            </a>
          ))}
        </nav>
        <NavbarActions client:load />
      </div>
      <!-- Mobile nav -->
      <MobileNavbar client:idle />
    </div>
  </div>
</header>
