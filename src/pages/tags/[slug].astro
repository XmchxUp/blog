---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import PostsByYear from "@/components/PostsByYear.astro";

export async function getStaticPaths() {
  const { filterPublishedPosts } = await import("@/lib/utils");
  const allPosts = filterPublishedPosts(await getCollection("post"));
  const tagSet = new Set<string>();
  allPosts.forEach((p) => p.data.tags?.forEach((t) => tagSet.add(t)));
  const tags = [...tagSet];

  return tags.map((tag) => ({
    params: { slug: tag },
    props: {
      slug: tag,
      posts: allPosts.filter((p) =>
        p.data.tags?.some((t) => t.toLowerCase() === tag.toLowerCase())
      ),
    },
  }));
}

const { posts, slug } = Astro.props;
---

<BaseLayout title={`Tag: ${slug}`}>
  <PostsByYear title={`Tag: ${slug}`} posts={posts} />
</BaseLayout>
