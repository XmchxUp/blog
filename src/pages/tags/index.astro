---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import AllAnything from "@/components/AllAnything.astro";
import { getAllTag, sortByCount, filterPublishedPosts } from "@/lib/utils";

const allPosts = filterPublishedPosts(await getCollection("post"));
const ALL_TAG = getAllTag(allPosts);
const items = sortByCount(ALL_TAG, true);
---

<BaseLayout title="Tags">
  <AllAnything title="Tags" items={items} counts={ALL_TAG} />
</BaseLayout>
