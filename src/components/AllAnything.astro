---
interface Props {
  title: string;
  items: string[];
  counts?: Record<string, number>;
}

const { title, items, counts } = Astro.props;
const basePath = title.toLowerCase();
---

<div class="flex flex-col gap-4">
  <div class="rounded-xl border bg-card shadow px-5 py-4 flex items-center justify-between">
    <h1 class="text-xl font-bold tracking-tight">{title}</h1>
    <span class="text-sm text-muted-foreground">{items.length} {basePath}</span>
  </div>

  <div class="rounded-xl border bg-card shadow p-5">
    <div class="flex flex-wrap gap-2">
      {items.map((item) => (
        <a
          href={`/${basePath}/${item}`}
          class="inline-flex items-center gap-1.5 rounded-full border border-border px-3 py-1.5 text-sm hover:bg-accent hover:text-accent-foreground transition-colors group"
        >
          <span>{item}</span>
          {counts?.[item] && (
            <span class="text-xs text-muted-foreground group-hover:text-accent-foreground tabular-nums">
              {counts[item]}
            </span>
          )}
        </a>
      ))}
    </div>
  </div>
</div>
