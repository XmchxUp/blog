---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import AllAnything from "@/components/AllAnything.astro";
import { getAllArchive, sortByDate, filterPublishedPosts } from "@/lib/utils";

const allPosts = filterPublishedPosts(await getCollection("post"));
const ALL_ARCHIVE = getAllArchive(allPosts);
const items = sortByDate(ALL_ARCHIVE, true);
---

<BaseLayout title="Archives">
  <AllAnything title="Archives" items={items} />
</BaseLayout>
