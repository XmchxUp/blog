---
import { getEntry, render } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { formatDate } from "@/lib/utils";

const entry = await getEntry("post", "hobby_project");
if (!entry) return Astro.redirect("/404");
const { Content } = await render(entry);
---

<BaseLayout title="Hobby Projects" description={entry.data.description}>
  <div class="w-full flex flex-col gap-8 min-w-0">
    <article class="print:rounded-none rounded-xl print:border-none border print:bg-transparent bg-card text-card-foreground print:shadow-none shadow w-full">
      <div class="flex flex-col space-y-1.5 p-6 pb-4">
        <h1 class="text-2xl font-medium tracking-tight">{entry.data.title}</h1>
        <p class="text-muted-foreground text-sm">
          <time>{formatDate(entry.data.date)}</time>
        </p>
      </div>
      <div data-orientation="horizontal" role="none" class="shrink-0 bg-border h-[1px] w-full"></div>
      <div class="p-6 pt-4">
        <div class="prose prose-slate dark:prose-invert prose-lg max-w-none text-pretty hyphens-auto">
          <Content />
        </div>
      </div>
    </article>
  </div>
</BaseLayout>
