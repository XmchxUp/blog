---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout title="404 - Page Not Found">
  <div class="w-full flex flex-col items-center justify-center gap-6 py-24 min-w-0">
    <h1 class="text-6xl font-bold text-muted-foreground">404</h1>
    <p class="text-xl text-muted-foreground">Page not found.</p>
    <a href="/" class="text-sm underline underline-offset-4 hover:text-primary transition-colors">
      Back to home
    </a>
  </div>
</BaseLayout>
