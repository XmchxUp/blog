---
import { categorizedPostsByYear, getPostSlug, type PostEntry } from "@/lib/utils";

interface Props {
  title: string;
  posts: PostEntry[];
}

const { title, posts } = Astro.props;
const postsM = categorizedPostsByYear(posts);
const years = Object.keys(postsM).sort((a, b) => parseInt(b) - parseInt(a));
---

<div class="flex flex-col gap-4">
  <div class="rounded-xl border bg-card shadow px-5 py-4 flex items-center justify-between">
    <h1 class="text-xl font-bold tracking-tight">{decodeURIComponent(title)}</h1>
    <span class="text-sm text-muted-foreground">{posts.length} posts</span>
  </div>

  <div class="rounded-xl border bg-card shadow overflow-hidden">
    {years.map((year, yi) => (
      <>
        <div class={`px-5 py-2 bg-muted/40 flex items-center gap-2 ${yi > 0 ? "border-t border-border" : ""}`}>
          <span class="text-xs font-semibold uppercase tracking-wider text-muted-foreground">{year}</span>
          <span class="text-xs text-muted-foreground/60">· {postsM[year].length}</span>
        </div>
        {postsM[year].map((post, i) => (
          <a
            href={`/post/${getPostSlug(post.id)}`}
            class={`flex items-center gap-3 px-5 py-2.5 hover:bg-accent/50 transition-colors group ${i < postsM[year].length - 1 ? "border-b border-border/40" : ""}`}
          >
            <time class="text-xs text-muted-foreground tabular-nums shrink-0 w-10">
              {new Date(post.data.date).toLocaleDateString("en-US", { month: "2-digit", day: "2-digit" })}
            </time>
            <span class="text-sm font-medium flex-grow truncate group-hover:text-primary transition-colors">
              {post.data.title}
            </span>
            <span class="text-xs text-muted-foreground shrink-0 hidden sm:inline-flex items-center border border-border/60 rounded-full px-2 py-0.5">
              {post.data.category}
            </span>
          </a>
        ))}
      </>
    ))}
  </div>
</div>
